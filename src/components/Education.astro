---
interface Degree {
  period:       string;
  degree:       string;
  field:        string;
  institution:  string;
  type:         'master' | 'bachelor' | 'associate';
  note?:        string;
  current?:     boolean;
}

const education: Degree[] = [
  {
    period:      '2026 – 2027',
    degree:      "Master's Degree",
    field:       'Electrical Engineering and Computing',
    institution: 'Mackenzie Presbyterian University · School of Computing and Informatics',
    type:        'master',
    current:     true,
    note:        'Research focus: Multimodal Drone Detection (computer vision, radar, RF signals)',
  },
  {
    period:      '2022 – 2024',
    degree:      "Bachelor's Degree",
    field:       'Computer & Information Systems',
    institution: 'Mackenzie Presbyterian University · School of Computing and Informatics',
    type:        'bachelor',
    note:        'Undergraduate thesis published in IEEE Transactions on Image Processing (under review)',
  },
  {
    period:      '2022 – 2024',
    degree:      "Associate's Degree",
    field:       'Computer Systems Analysis and Development',
    institution: 'Mackenzie Presbyterian University · School of Computing and Informatics',
    type:        'associate',
  },
];

const certifications = [
  { name: 'AWS Academy Machine Learning Foundations', issuer: 'Amazon Web Services', year: '2024' },
  { name: 'AWS Academy Cloud Foundations',            issuer: 'Amazon Web Services', year: '2024' },
  { name: 'Red Hat System Administration I & II',     issuer: 'Red Hat',             year: '2024' },
  { name: 'Test of English as a Foreign Language (TOEFL)',                 issuer: 'ETS',            year: '2018' },
  { name: 'Certificate of Proficiency in English (CPE)',issuer: 'Cambridge',         year: '2016' },
];

const typeIcon: Record<Degree['type'], string> = {
  master:    '🎓',
  bachelor:  '📚',
  associate: '📖',
};
---

<section class="section section--alt" id="education">
  <div class="container">
    <header data-animate>
      <p class="section-label">// education</p>
      <h2 class="section-title">Academic Background</h2>
    </header>

    <div class="edu-grid">
      <div class="edu-degrees">
        <h3 class="edu-sub-title" data-animate>Degrees</h3>
        <div class="degrees-list">
          {education.map((ed, i) => (
            <div class={`card edu-card ${ed.current ? 'edu-card--current' : ''}`} data-animate data-delay={String(i + 1)}>
              <div class="edu-header">
                <span class="edu-icon" aria-hidden="true">{typeIcon[ed.type]}</span>
                <div>
                  <div class="edu-meta">
                    <span class="edu-period">{ed.period}</span>
                    {ed.current && <span class="tag tag--green" style="font-size:0.65rem;padding:0.1em 0.5em;">In progress</span>}
                  </div>
                  <h4 class="edu-degree">{ed.degree}</h4>
                  <p class="edu-field">{ed.field}</p>
                  <p class="edu-institution">{ed.institution}</p>
                  {ed.note && <p class="edu-note">{ed.note}</p>}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="edu-certs" data-animate data-delay="2">
        <h3 class="edu-sub-title">Certifications & Honors</h3>
        <div class="certs-list">
          {certifications.map((cert, i) => (
            <div class="cert-item" data-animate data-delay={String(i + 1)}>
              <div class="cert-dot" aria-hidden="true"></div>
              <div>
                <p class="cert-name">{cert.name}</p>
                <p class="cert-issuer">{cert.issuer} · {cert.year}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .edu-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 4rem;
    align-items: start;
  }

  .edu-sub-title {
    font-size: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin-bottom: 1.25rem;
  }

  /* Degrees */
  .degrees-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .edu-card { padding: 1.25rem 1.5rem; }
  .edu-card--current { border-color: rgba(59, 130, 246, 0.35); }

  .edu-header {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .edu-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 0.2rem;
  }

  .edu-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.3rem;
  }

  .edu-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--c-blue-400);
    font-weight: 500;
  }

  .edu-degree {
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-text-1);
    margin-bottom: 0.15rem;
  }

  .edu-field {
    font-size: 0.9rem;
    color: var(--c-blue-400);
    font-weight: 500;
    margin-bottom: 0.2rem;
  }

  .edu-institution {
    font-size: 0.825rem;
    color: var(--c-text-3);
    line-height: 1.4;
    margin-bottom: 0.4rem;
  }

  .edu-note {
    font-size: 0.825rem;
    color: var(--c-text-2);
    font-style: italic;
    line-height: 1.5;
    padding-top: 0.4rem;
    border-top: 1px solid var(--c-border);
    margin-top: 0.4rem;
  }

  /* Certifications */
  .edu-certs {
    position: sticky;
    top: 5rem;
  }
  .certs-list {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .cert-item {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--c-border);
  }
  .cert-item:last-child { border-bottom: none; }

  .cert-dot {
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-blue-500);
    margin-top: 0.45rem;
  }

  .cert-name {
    font-size: 0.875rem;
    color: var(--c-text-1);
    font-weight: 500;
    margin-bottom: 0.2rem;
    line-height: 1.4;
  }

  .cert-issuer {
    font-size: 0.75rem;
    color: var(--c-text-3);
    font-family: 'JetBrains Mono', monospace;
  }

  @media (max-width: 900px) {
    .edu-grid { grid-template-columns: 1fr; gap: 3rem; }
    .edu-certs { position: static; }
  }
</style>
