---
---
<header class="navbar" id="navbar">
  <nav class="container nav-inner">
    <a href="#hero" class="nav-logo" aria-label="Home">
      <span class="logo-bracket">&lt;</span>GMT<span class="logo-bracket">/&gt;</span>
    </a>

    <ul class="nav-links" id="nav-links" role="list">
      <li><a href="#about">About</a></li>
      <li><a href="#experience">Experience</a></li>
      <li><a href="#research">Research</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#oss">Open Source</a></li>
      <li><a href="#contact" class="btn btn-outline nav-cta">Contact</a></li>
    </ul>

    <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<script>
  const navbar    = document.getElementById('navbar')!;
  const hamburger = document.getElementById('hamburger')!;
  const navLinks  = document.getElementById('nav-links')!;

  // Scroll shadow
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  // Mobile toggle
  hamburger.addEventListener('click', () => {
    const open = navLinks.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(open));
    hamburger.classList.toggle('open', open);
  });

  // Close on link click
  navLinks.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      navLinks.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    inset-inline: 0;
    z-index: 100;
    transition: background var(--transition), box-shadow var(--transition);
  }

  .navbar.scrolled {
    background: rgba(4, 9, 28, 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 1px 0 rgba(37, 99, 235, 0.2);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  /* Logo */
  .nav-logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--c-text-1);
    letter-spacing: -0.03em;
    text-decoration: none;
    transition: color var(--transition);
  }
  .nav-logo:hover { color: var(--c-text-1); }
  .logo-bracket { color: var(--c-blue-400); }

  /* Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a:not(.btn) {
    display: inline-block;
    padding: 0.4rem 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--c-text-2);
    border-radius: var(--radius-sm);
    transition: color var(--transition), background var(--transition);
  }
  .nav-links a:not(.btn):hover,
  .nav-links a:not(.btn).active {
    color: var(--c-blue-400);
    background: rgba(59, 130, 246, 0.08);
  }

  .nav-cta { font-size: 0.875rem !important; padding: 0.45rem 1rem !important; }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 1.5rem;
    height: 1.125rem;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    gap: 0.3rem;
  }
  .hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--c-text-2);
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile */
  @media (max-width: 768px) {
    .hamburger { display: flex; }

    .nav-links {
      position: fixed;
      inset: 4rem 0 0;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      background: rgba(4, 9, 28, 0.98);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-8px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .nav-links.open {
      opacity: 1;
      pointer-events: all;
      transform: none;
    }
    .nav-links a:not(.btn) { font-size: 1.125rem; padding: 0.6rem 2rem; }
    .nav-cta { margin-top: 0.5rem; }
  }
</style>
