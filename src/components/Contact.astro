---

<section class="section section--alt" id="contact">
  <div class="container">
    <header data-animate>
      <p class="section-label">// contact</p>
      <h2 class="section-title">Get In Touch</h2>
    </header>

    <div class="contact-inner">
      <div class="contact-text" data-animate data-delay="1">
        <p>
          I'm available for <strong>freelance engineering work</strong>, focused technical consulting,
          research collaborations, and selected product builds.
          Whether you're a recruiter, a fellow engineer, or a researcher — my inbox is open.
        </p>
        <p>The best way to reach me is via email:</p>
        <a href="mailto:gabriel@tkacz.dev.br" class="email-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          gabriel@tkacz.dev.br
        </a>
      </div>

      <div class="contact-links" data-animate data-delay="2">
        {links.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="contact-link-card card">
            <div class={`clc-icon ${link.viewBox !== '0 0 24 24' ? 'clc-icon--wide' : ''}`}>
              <svg width={link.viewBox !== '0 0 24 24' ? 44 : 20} height="20" viewBox={link.viewBox} fill={link.viewBox !== '0 0 24 24' ? 'none' : 'currentColor'} aria-hidden="true">
                <Fragment set:html={link.icon} />
              </svg>
            </div>
            <div>
              <p class="clc-label">{link.label}</p>
              <p class="clc-desc">{link.desc}</p>
            </div>
            <svg class="clc-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M7 17 17 7M7 7h10v10"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-text p {
    color: var(--c-text-2);
    font-size: 1.0125rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .contact-text strong { color: var(--c-text-1); font-weight: 600; }

  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--c-blue-400);
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--c-border-hover);
    border-radius: var(--radius);
    transition: all var(--transition);
    background: rgba(59, 130, 246, 0.05);
  }
  .email-link:hover {
    color: var(--c-blue-300);
    background: rgba(59, 130, 246, 0.1);
    border-color: var(--c-blue-400);
    transform: translateY(-2px);
    box-shadow: var(--c-glow);
    text-decoration: none;
  }

  /* Link cards */
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-link-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: all var(--transition);
  }
  .contact-link-card:hover { text-decoration: none; }

  .clc-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-sm);
    background: rgba(59, 130, 246, 0.1);
    color: var(--c-blue-400);
    flex-shrink: 0;
    transition: background var(--transition), color var(--transition);
  }

  .clc-icon--wide {
    width: 4.25rem;
    justify-content: flex-start;
    padding-inline: 0.45rem;
  }
  .contact-link-card:hover .clc-icon {
    background: rgba(59, 130, 246, 0.2);
    color: var(--c-blue-300);
  }

  .clc-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--c-text-1);
    margin-bottom: 0.15rem;
  }
  .clc-desc {
    font-size: 0.8rem;
    color: var(--c-text-3);
  }

  .clc-arrow {
    margin-left: auto;
    color: var(--c-text-3);
    flex-shrink: 0;
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: all var(--transition);
  }
  .contact-link-card:hover .clc-arrow {
    opacity: 1;
    transform: translate(0, 0);
    color: var(--c-blue-400);
  }

  @media (max-width: 768px) {
    .contact-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
