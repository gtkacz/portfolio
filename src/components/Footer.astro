---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href="#hero" class="footer-logo" aria-label="Back to top">
        <span class="logo-bracket">&lt;</span>tkacz.dev<span class="logo-bracket">/&gt;</span>
      </a>
      <p class="footer-copy">
        &copy; {year} Gabriel Mitelman Tkacz · Built with
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
        · São Paulo, Brazil
      </p>
    </div>

    <div class="footer-links">
      <a href="https://github.com/gtkacz" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/in/gtkacz/" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="LinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="mailto:gabriel@tkacz.dev.br" class="footer-link" aria-label="Email">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--c-border);
    padding-block: 2rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    /* font-weight: 700; */
    color: var(--c-text-1);
    text-decoration: none;
  }
  .footer-logo:hover { color: var(--c-text-1); text-decoration: none; }
  .logo-bracket { color: var(--c-blue-400); }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--c-text-3);
  }
  .footer-copy a {
    color: var(--c-blue-400);
    font-weight: 500;
  }
  .footer-copy a:hover { color: var(--c-blue-300); }

  .footer-links {
    display: flex;
    gap: 0.25rem;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-sm);
    color: var(--c-text-3);
    transition: all var(--transition);
  }
  .footer-link:hover {
    color: var(--c-blue-400);
    background: rgba(59, 130, 246, 0.08);
  }

  @media (max-width: 480px) {
    .footer-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
