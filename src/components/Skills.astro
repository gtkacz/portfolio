---
interface SkillGroup {
  label:  string;
  icon:   string;
  color:  'blue' | 'cyan' | 'purple' | 'green';
  skills: string[];
}

const groups: SkillGroup[] = [
  {
    label:  'Languages',
    icon:   '<path d="m8 8-4 4 4 4" /><path d="m16 8 4 4-4 4" /><path d="m14 4-4 16" />',
    color:  'blue',
    skills: ['Python', 'TypeScript', 'JavaScript', 'Java', 'Rust', 'PHP', 'SQL', 'Bash'],
  },
  {
    label:  'Frameworks & Libraries',
    icon:   '<path d="M12 15.5A3.5 3.5 0 1 0 12 8.5a3.5 3.5 0 0 0 0 7Z" /><path d="M19.4 15a1 1 0 0 0 .2 1.1l.1.1a1 1 0 0 1 0 1.4l-1.3 1.3a1 1 0 0 1-1.4 0l-.1-.1a1 1 0 0 0-1.1-.2 1 1 0 0 0-.6.9V20a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-.2a1 1 0 0 0-.6-.9 1 1 0 0 0-1.1.2l-.1.1a1 1 0 0 1-1.4 0l-1.3-1.3a1 1 0 0 1 0-1.4l.1-.1a1 1 0 0 0 .2-1.1 1 1 0 0 0-.9-.6H4a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1h.2a1 1 0 0 0 .9-.6 1 1 0 0 0-.2-1.1l-.1-.1a1 1 0 0 1 0-1.4l1.3-1.3a1 1 0 0 1 1.4 0l.1.1a1 1 0 0 0 1.1.2 1 1 0 0 0 .6-.9V4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v.2a1 1 0 0 0 .6.9 1 1 0 0 0 1.1-.2l.1-.1a1 1 0 0 1 1.4 0l1.3 1.3a1 1 0 0 1 0 1.4l-.1.1a1 1 0 0 0-.2 1.1 1 1 0 0 0 .9.6H20a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-.2a1 1 0 0 0-.9.6Z" />',
    color:  'cyan',
    skills: [
      'Django', 'Django REST Framework', 'Flask', 'Pydantic', 'Graphene',
      'Vue.js', 'Nuxt', 'Vite', 'Node.js',
      'Spring Boot', 'jOOQ', 'Thymeleaf',
      'PyTorch', 'scikit-learn', 'OpenCV', 'HuggingFace', 'Pandas', 'Celery',
    ],
  },
  {
    label:  'Cloud & DevOps',
    icon:   '<path d="M6 19h11a4 4 0 0 0 .4-8A5 5 0 0 0 7 9a4 4 0 0 0-1 10Z" /><path d="M12 10v6" /><path d="m9.5 13 2.5 3 2.5-3" />',
    color:  'blue',
    skills: [
      'AWS (S3, RDS, EC2, Elastic Beanstalk, CloudWatch, Route 53, CodePipeline)',
      'Docker', 'Docker Compose', 'GitHub Actions', 'GitLab CI/CD', 'Travis CI',
      'Apache Kafka', 'Apache Airflow', 'Gunicorn', 'Unix/Linux', 'GNU Make',
    ],
  },
  {
    label:  'Databases',
    icon:   '<ellipse cx="12" cy="5" rx="7" ry="3" /><path d="M5 5v6c0 1.7 3.1 3 7 3s7-1.3 7-3V5" /><path d="M5 11v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" />',
    color:  'green',
    skills: ['PostgreSQL', 'MySQL', 'DuckDB', 'SQLite', 'Microsoft SQL Server', 'H2', 'MongoDB', 'Redis'],
  },
  {
    label:  'AI & Machine Learning',
    icon:   '<rect x="7" y="7" width="10" height="10" rx="2" /><path d="M9 2v3" /><path d="M15 2v3" /><path d="M9 12h.01" /><path d="M15 12h.01" /><path d="M12 17v4" /><path d="M4 10h3" /><path d="M17 10h3" />',
    color:  'purple',
    skills: [
      'Machine Learning', 'Deep Learning', 'Computer Vision', 'NLP',
      'RAG', 'LLM Fine-Tuning', 'Zero-Shot Classification',
      'Cross-Encoder Rerankers', 'Natural Computing',
      'Mathematical Modelling', 'Statistical Analysis', 'Data Engineering',
    ],
  },
  {
    label:  'Engineering Practices',
    icon:   '<path d="m3 21 8-18 10 10-18 8Z" /><path d="m14 6 4 4" /><path d="M7 15h.01" />',
    color:  'blue',
    skills: [
      'SOLID Principles', 'GRASP', 'Clean Architecture', 'REST API Design',
      'GraphQL', 'Scrum', 'Kanban', 'TDD', 'CI/CD', 'Database Optimization',
    ],
  },
];

const colorMap: Record<string, string> = {
  blue:   'tag',
  cyan:   'tag tag--cyan',
  purple: 'tag tag--purple',
  green:  'tag tag--green',
};
---

<section class="section section--alt" id="skills">
  <div class="container">
    <header data-animate>
      <p class="section-label">// skills</p>
      <h2 class="section-title">Technical Skills</h2>
    </header>

    <div class="skills-grid">
      {groups.map((group, i) => (
        <div class="card skill-group" data-animate data-delay={String((i % 3) + 1)}>
          <div class="group-header">
            <svg class="group-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <Fragment set:html={group.icon} />
            </svg>
            <h3 class="group-label">{group.label}</h3>
          </div>
          <div class="group-tags">
            {group.skills.map((skill) => (
              <span class={colorMap[group.color]}>{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .skill-group { display: flex; flex-direction: column; gap: 1rem; }

  .group-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--c-border);
  }

  .group-icon {
    color: var(--c-blue-400);
    flex-shrink: 0;
  }

  .group-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--c-text-1);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
  }

  .group-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-content: flex-start;
  }

  @media (max-width: 1024px) {
    .skills-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
