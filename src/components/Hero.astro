        <a href="https://www.sbc.org.br/" target="_blank" rel="noopener noreferrer" class="social-link social-link--brand" title="SBC Member">
          <img src="/brands/sbc.svg" alt="SBC logo" width="88" height="24" />
        </a>
        <a href="https://orcid.org/0009-0004-3619-4561" target="_blank" rel="noopener noreferrer" class="social-link" title="ORCID">
