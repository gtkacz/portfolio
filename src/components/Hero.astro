<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-top: 4rem; /* navbar height */
  }

  /* Background glow */
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 90% 60% at 50% -10%, rgba(59, 130, 246, 0.15) 0%, transparent 70%),
      radial-gradient(ellipse 45% 35% at 82% 88%, rgba(37, 99, 235, 0.08) 0%, transparent 65%),
      radial-gradient(ellipse 40% 25% at 15% 82%, rgba(29, 78, 216, 0.08) 0%, transparent 65%);
    pointer-events: none;
    filter: blur(40px);
  }

  /* Dot grid */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(146, 176, 240, 0.16) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 75%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 4rem;
    padding-block: clamp(3rem, 8vw, 5rem);
    position: relative;
    z-index: 1;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-pill);
    background: rgba(59, 130, 246, 0.06);
    border: 1px solid rgba(59, 130, 246, 0.16);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--c-text-2);
    margin-bottom: 1rem;
    width: fit-content;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-blue-400);
  }

  /* Greeting */
  .hero-greeting {
    font-size: 1.1rem;
    color: var(--c-text-2);
    margin-bottom: 0.4rem;
    font-weight: 400;
  }

  /* Name */
  .hero-name {
    font-size: clamp(2.5rem, 6.5vw, 4.75rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  /* Role pills */
  .hero-roles {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }
  .role-pill {
    display: inline-block;
    padding: 0.3em 0.85em;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--c-blue-300);
    letter-spacing: 0.01em;
    transition: border-color var(--transition), background var(--transition);
  }
  .role-pill:hover {
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.1);
  }
  .role-sep {
    color: var(--c-text-3);
    font-weight: 300;
  }

  /* Bio */
  .hero-bio {
    max-width: 55ch;
    color: var(--c-text-2);
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }
  .hero-bio .accent {
    color: var(--c-accent-pink);
    font-weight: 600;
    text-shadow: 0 0 10px rgba(59, 130, 246, 0.25);
  }

  /* CTA buttons */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  /* Social links */
  .hero-social {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--c-text-3);
    transition: color 0.3s;
  }
  .social-link:hover {
    color: var(--c-text-1);
  }

  .social-link--brand svg {
    width: auto;
    height: 18px;
  }

  /* ---- Visual orbits ---- */
  .hero-visual {
    position: relative;
    width: 280px;
    height: 280px;
    flex-shrink: 0;
  }
  .orbit-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0 18px rgba(255, 255, 255, 0.02);
    animation: spin 18s linear infinite;
  }
  .ring-1 { inset: 0;         }
  .ring-2 { inset: 28px;  animation-direction: reverse; animation-duration: 14s; }
  .ring-3 { inset: 56px;  animation-duration: 22s; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .orbit-core {
    position: absolute;
    inset: 50%;
    transform: translate(-50%, -50%);
    width: 128px;
    height: 128px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
