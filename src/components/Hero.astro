    </div>

    <div class="hero-visual" data-animate data-delay="3" aria-hidden="true">
      <div class="orbit-ring ring-1"></div>
      <div class="orbit-ring ring-2"></div>
      <div class="orbit-ring ring-3"></div>
      <div class="orbit-core">
        <span class="core-text">tkacz.dev</span>
      </div>
      <div class="orbit-satellite s1">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="var(--c-blue-400)"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
      </div>
      <div class="orbit-satellite s2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--c-cyan)"><circle cx="12" cy="12" r="3"/><path stroke="currentColor" stroke-width="2" fill="none" d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path stroke="currentColor" stroke-width="2" fill="none" d="M2 12h20"/></svg>
      </div>
      <div class="orbit-satellite s3">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--c-blue-300)"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
      </div>
    </div>
  </div>

  <a href="#about" class="scroll-cue" aria-label="Scroll to About">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </a>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-top: 4rem; /* navbar height */
  }

  /* Background glow */
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 90% 60% at 50% -10%, rgba(37, 99, 235, 0.2) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 85% 90%, rgba(34, 211, 238, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Dot grid */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(99, 145, 230, 0.12) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 75%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 4rem;
    padding-block: clamp(3rem, 8vw, 5rem);
    position: relative;
    z-index: 1;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-pill);
    background: rgba(59, 130, 246, 0.06);
    border: 1px solid rgba(59, 130, 246, 0.16);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--c-text-2);
    margin-bottom: 1rem;
    width: fit-content;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-blue-400);
  }

  /* Greeting */
  .hero-greeting {
    font-size: 1.1rem;
    color: var(--c-text-2);
    margin-bottom: 0.4rem;
    font-weight: 400;
  }

  /* Name */
  .hero-name {
    font-size: clamp(2.5rem, 6.5vw, 4.75rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  /* Role pills */
  .hero-roles {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }
  .role-pill {
    display: inline-block;
    padding: 0.3em 0.85em;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: var(--radius-pill);
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.3);
    color: var(--c-blue-300);
    letter-spacing: 0.01em;
  }
  .role-sep {
    color: var(--c-text-3);
    font-weight: 300;
  }

  /* Bio */
  .hero-bio {
    max-width: 55ch;
    color: var(--c-text-2);
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }
  .hero-bio .accent { color: var(--c-blue-400); font-weight: 500; }

  /* CTA buttons */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  /* Social links */
  .hero-social {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--c-text-3);
    transition: color var(--transition);
  }
  .social-link:hover { color: var(--c-blue-400); }

  .social-link--brand svg {
    width: auto;
    height: 14px;
  }

  .social-link--brand img {
    width: auto;
    height: 14px;
  }

  .hero-social .social-link[title="Lattes CV"] img {
    width: auto;
    height: 14px;
  }

  /* ---- Visual orbits ---- */
  .hero-visual {
    position: relative;
    width: 280px;
    height: 280px;
    flex-shrink: 0;
  }
  .orbit-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid var(--c-border);
    animation: spin 18s linear infinite;
  }
  .ring-1 { inset: 0;         }
  .ring-2 { inset: 28px;  animation-direction: reverse; animation-duration: 14s; }
  .ring-3 { inset: 56px;  animation-duration: 22s; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .orbit-core {
    position: absolute;
    inset: 50%;
    transform: translate(-50%, -50%);
    width: 128px;
    height: 128px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.35) 0%, rgba(37, 99, 235, 0.08) 70%);
    border: 1px solid var(--c-border-hover);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: glow-pulse 3s ease-in-out infinite;
  }
  .core-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--c-blue-400);
    letter-spacing: -0.03em;
  }
  @keyframes glow-pulse {
    0%, 100% { box-shadow: 0 0 20px rgba(59, 130, 246, 0.2); }
    50%       { box-shadow: 0 0 40px rgba(59, 130, 246, 0.4); }
  }

  /* Satellites */
  .orbit-satellite {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--c-surface-2);
    border: 1px solid var(--c-border);
  }
  .s1 { top: 0;    left: 50%;  transform: translate(-50%, -50%); }
  .s2 { top: 50%;  right: 0;   transform: translate(50%, -50%); }
  .s3 { bottom: 8px; left: 10%; transform: translate(0, 50%); }

  /* Scroll cue */
  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--c-text-3);
    animation: bounce 2s ease-in-out infinite;
    transition: color var(--transition);
  }
  .scroll-cue:hover { color: var(--c-blue-400); }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero-visual { display: none; }
  }
  @media (max-width: 480px) {
    .hero-name { font-size: clamp(2rem, 9vw, 3rem); }
    .hero-actions { flex-direction: column; width: fit-content; }
  }
</style>
