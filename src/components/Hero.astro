<section class="hero" id="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-grid" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-content">
      <!-- <div class="hero-badge" data-animate>
        <span class="badge-dot"></span>
        <span>Available for freelance engineering and consulting</span>
      </div> -->

      <p class="hero-greeting" data-animate data-delay="1">Hello, I'm</p>

      <h1 class="hero-name gradient-text" data-animate data-delay="2">
        Gabriel Mitelman Tkacz
      </h1>

      <div class="hero-roles" data-animate data-delay="3" aria-label="Roles">
        <span class="role-pill">Software Engineer</span>
        <span class="role-sep">·</span>
        <span class="role-pill">AI Researcher</span>
        <span class="role-sep">·</span>
        <span class="role-pill">FOSS Advocate</span>
      </div>

      <p class="hero-bio" data-animate data-delay="4">
        I design and build production-grade distributed backends, end-to-end machine learning pipelines, and
        accessible full-stack web applications. My work spans quantitative finance, energy
        trading, and global eCommerce automation across three countries. IEEE member, academic
        researcher, and active FOSS contributor.
        Based in <span class="accent">São Paulo, Brazil</span>.
      </p>

