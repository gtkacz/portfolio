          <div>
            <p class="location-city">Member</p>
            <p class="location-country">Institute of Electrical and Electronics Engineers</p>
          </div>
        </div>

        <div class="about-member card">
          <svg class="member-logo" width="28" height="28" viewBox="0 0 180 249" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M9 14L9 65L11 65C11.1332 49.1248 20.7436 35.5249 32 25.0903C36.074 21.3137 42.0145 18.6552 45 14L9 14M42 91C71.6708 79.5541 108.056 79.0027 135 98.0432C141.968 102.967 148.198 109.661 152.546 117C154.014 119.478 156.302 122.93 155.443 125.961C154.521 129.213 150.623 131.486 148 133.251C140.158 138.528 131.13 141.671 122 143.87C93.9517 150.626 61.678 146.167 37 130.935C30.9429 127.197 25.1252 122.914 20.0039 117.961C16.3749 114.451 13.58 110.232 9 108L9 231L162 231L162 182C162 173.883 161.003 165.038 162.144 157C162.944 151.369 167.425 146.259 169.547 141C173.497 131.213 174.566 119.119 171.251 109C166.623 94.8756 155.059 85.0573 142 78.784C118.812 67.6445 90.1858 65.6247 66 74.814C57.5305 78.032 47.2191 82.2635 41 89C37.9232 85.6269 35.2618 82.167 33.3241 78C22.3849 54.4759 41.7069 37.4678 54 20C43.0056 23.1734 34.1406 31.8346 27.7215 41C13.5578 61.2234 7.13912 90.5462 22.5949 112C38.2026 133.665 69.5466 141.362 95 141.985C110.224 142.358 126.628 139.76 140 132.127C148.04 127.538 152.892 123.972 147.532 115.005C146.76 113.714 145.832 112.337 144.671 111.361C141.173 108.42 136.7 111.089 133 112.333C124.989 115.025 116.485 116.818 108 116.985C84.1338 117.454 58.9232 107.572 42 91M177 77C174.325 80.7972 166.643 85.521 166.022 90.0895C165.666 92.7031 167.948 95.7287 169 98L171 98C174.224 91.093 178.317 84.7751 179 77L177 77z M17 210C17 212.976 16.1108 217.897 18.0278 220.411C19.9193 222.892 25.1583 223.118 28 223.561C38.9863 225.273 52.497 221.406 54.5177 209C56.3955 197.472 45.3332 191.149 37 186.135C33.54 184.053 26.7563 179.988 28.4074 175.019C31.4379 165.899 43.9675 171.975 50 173C49.9981 170.489 50.6006 166.723 48.9722 164.589C46.9863 161.986 41.9245 162.085 39 162.015C30.4043 161.807 19.6367 163.45 16.6528 173C11.0039 191.08 35.3309 192.475 41.6813 204.09C44.5757 209.384 40.5297 214.892 35 215.757C28.7246 216.739 22.30