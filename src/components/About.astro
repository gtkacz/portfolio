---
const stats = [
  { value: '3+',  label: 'Years of professional experience' },
  { value: '4',   label: 'Companies across 3 countries' },
  { value: '20+', label: 'Open source contributions' },
  { value: '2',   label: 'Peer-reviewed publications' },
];

const highlights = [
  {
    className: 'tag tag--cyan',
    label: 'Performance-obsessed backend',
    icon: '<path d="M13 2 3 14h7l-1 8 10-12h-7z" />',
  },
  {
    className: 'tag tag--purple',
    label: 'ML / AI pipelines',
    icon: '<path d="M12 3v4" /><path d="M12 17v4" /><path d="M3 12h4" /><path d="M17 12h4" /><rect x="7" y="7" width="10" height="10" rx="2" /><path d="M9.5 9.5h5v5h-5z" />',
  },
  {
    className: 'tag',
    label: 'UI/UX prototyping & implementation',
    icon: '<path d="m4 16 6-6 4 4 6-6" /><path d="M20 10V4h-6" />',
  },
  {
    className: 'tag tag--green',
    label: 'FOSS contributor',
    icon: '<path d="M12 2a10 10 0 1 0 10 10" /><path d="M2 12h20" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z" />',
  },
  {
    className: 'tag tag--cyan',
    label: 'Cloud & DevOps',
    icon: '<path d="M6 19h11a4 4 0 0 0 .4-8A5 5 0 0 0 7 9a4 4 0 0 0-1 10Z" />',
  },
  {
    className: 'tag tag--purple',
    label: 'AI Research',
    icon: '<path d="M12 2v4" /><path d="M12 18v4" /><path d="M4.93 4.93 7.76 7.76" /><path d="M16.24 16.24 19.07 19.07" /><path d="M2 12h4" /><path d="M18 12h4" /><path d="M4.93 19.07 7.76 16.24" /><path d="M16.24 7.76 19.07 4.93" /><circle cx="12" cy="12" r="4" />',
  },
];
---
<section class="section section--alt" id="about">
  <div class="container">
    <header data-animate>
      <p class="section-label">// about</p>
      <h2 class="section-title">Who I Am</h2>
    </header>

    <div class="about-grid">
      <div class="about-text" data-animate data-delay="1">
        <p>
          I'm a <strong>full-stack software engineer</strong> based in São Paulo, Brazil, with a
          strong foundation across the entire product lifecycle — from designing high-throughput
          distributed systems and optimizing database queries, to building machine learning
          pipelines and crafting polished, accessible user interfaces.
        </p>
        <p>
          My professional journey has taken me through <strong>quantitative finance</strong>
          (Giant Steps Capital, Latin America's largest quant fund), <strong>energy trading</strong>
          (Libra Energia), and <strong>global eCommerce automation</strong> (FlxPoint), giving me
          a unique cross-domain perspective on what makes software <em>truly work</em> in production.
        </p>
        <p>
          I'm a genuine <strong>FOSS believer</strong> — I've authored and maintain several
          open-source libraries, and actively contribute to projects like Ruff, Django REST
          Framework, OpenBB, and more. Building in the open is how I give back to the community
          that shaped me as an engineer.
        </p>
        <p>
          Currently completing a <strong>Master's degree</strong> at Mackenzie Presbyterian
          University, where my research focuses on multimodal drone detection using computer vision,
          radar, and radio frequency analysis. My undergraduate thesis — a quantitative study on
          image preprocessing for dermatological AI — is under review at
          <em>IEEE Transactions on Image Processing</em>.
        </p>

        <div class="about-highlights">
          {highlights.map((highlight) => (
            <span class={highlight.className}>
              <svg class="highlight-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={highlight.icon} />
              </svg>
              {highlight.label}
            </span>
          ))}
        </div>
      </div>

      <div class="about-stats" data-animate data-delay="2">
        {stats.map((stat) => (
          <div class="stat-card card">
            <span class="stat-value gradient-text">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}

        <div class="about-location card" data-animate data-delay="3">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--c-blue-400)" stroke-width="2" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <div>
            <p class="location-city">São Paulo, SP</p>
            <p class="location-country">Brazil · GMT-3</p>
          </div>
        </div>

        <div class="about-ieee card">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--c-blue-400)" stroke-width="2" aria-hidden="true">
            <rect x="3" y="8" width="18" height="13" rx="2"/>
            <path d="M8 8V6a4 4 0 0 1 8 0v2"/>
            <circle cx="12" cy="14" r="2"/>
          </svg>
          <div>
            <p class="location-city">IEEE Member</p>
            <p class="location-country">ORCID: 0009-0004-3619-4561</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: start;
  }

  .about-text p {
    color: var(--c-text-2);
    margin-bottom: 1.25rem;
    font-size: 1.0125rem;
    line-height: 1.8;
  }
  .about-text strong { color: var(--c-text-1); font-weight: 600; }
  .about-text em     { color: var(--c-blue-400); font-style: normal; font-weight: 500; }

  .about-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  .about-highlights .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .highlight-icon {
    flex-shrink: 0;
  }

  /* Stats column */
  .about-stats {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: sticky;
    top: 5rem;
  }

  .stat-card {
    text-align: center;
    padding: 1.25rem 1rem;
  }
  .stat-value {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.4rem;
    letter-spacing: -0.03em;
  }
  .stat-label {
    font-size: 0.8rem;
    color: var(--c-text-3);
    line-height: 1.4;
  }

  .about-location,
  .about-ieee {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
  }
  .about-location svg,
  .about-ieee svg { flex-shrink: 0; }
  .location-city {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-text-1);
  }
  .location-country {
    font-size: 0.75rem;
    color: var(--c-text-3);
    font-family: 'JetBrains Mono', monospace;
  }

  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-stats { position: static; display: grid; grid-template-columns: 1fr 1fr; }
    .stat-card { grid-column: span 1; }
    .about-location,
    .about-ieee { grid-column: span 1; }
  }

  @media (max-width: 480px) {
    .about-stats { grid-template-columns: 1fr; }
  }
</style>
